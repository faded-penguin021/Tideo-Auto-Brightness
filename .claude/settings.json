{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(./gradlew:*)",
      "Bash(/opt/gradle/bin/gradle:*)",
      "Bash(scripts/setup-android-sdk.sh)",
      "Bash(./scripts/setup-android-sdk.sh)",
      "Bash(bash scripts/setup-android-sdk.sh)"
    ]
  }
}
