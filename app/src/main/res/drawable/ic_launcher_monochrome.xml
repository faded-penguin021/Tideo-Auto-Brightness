<?xml version="1.0" encoding="utf-8"?>
<!--
  Monochrome layer for themed icons (closes lint MonochromeLauncherIcon). Direction C simplified to one
  ink colour (designer spec §02 "Monochrome simplification"): 8 uniform ticks + solid sun disc + the
  full 305° dial track at one weight (no translucency / no fill-vs-empty split); the knob becomes a
  hollow ring so it still reads as a pointer against the arc. The launcher applies its own tint.

  S14: wrapped in the same 0.88 centre-scale group as ic_launcher_foreground so the themed icon matches
  the resized foreground (knob inside the r33 safe zone).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group android:pivotX="54" android:pivotY="54" android:scaleX="0.88" android:scaleY="0.88">

    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:pathData="M54,35 L54,29 M67.44,40.56 L71.68,36.32 M73,54 L79,54
            M67.44,67.44 L71.68,71.68 M54,73 L54,79 M40.56,67.44 L36.32,71.68
            M35,54 L29,54 M40.56,40.56 L36.32,36.32" />
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M54,41 A13,13 0 1,1 53.99,41 Z" />
    <!-- Full 305° dial track at one weight. -->
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:pathData="M54,24 A30,30 0 1,1 29.43,71.21" />
    <!-- Knob as a hollow ring (pointer notch). -->
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2.5"
        android:pathData="M84,49.5 A4.5,4.5 0 1,1 83.99,49.5 Z" />

    </group>
</vector>
