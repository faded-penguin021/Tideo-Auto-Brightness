<?xml version="1.0" encoding="utf-8"?>
<!--
  D-121: the geo-IP fallback moved from cleartext http://ip-api.com/json to HTTPS https://ipwho.is/,
  so the app makes NO cleartext requests. The previous ip-api.com cleartext exception is removed; this
  base-config pins cleartext OFF for every host (explicit hardening — it already matches the minSdk-31
  default, but states the HTTPS-only intent so a future targetSdk default change can't silently re-enable
  it, and keeps CodeQL's cleartext-traffic query satisfied).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
