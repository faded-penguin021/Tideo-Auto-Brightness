<?xml version="1.0" encoding="utf-8"?>
<!--
  Config for AabToastAccessibilityService (S12.7e, G2R-F50). The service is a presentation surface
  only: it draws the AAB flash messages as a system-wide accessibility overlay and consumes no
  events. canRetrieveWindowContent is false (we never read screen content); accessibilityFlags is
  default with no event types requested.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:canRetrieveWindowContent="false"
    android:description="@string/global_toasts_a11y_description"
    android:notificationTimeout="100" />
