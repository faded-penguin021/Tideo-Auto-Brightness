<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.WRITE_SETTINGS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- F89 audit (G2R-F89): special "Usage access" appop — needed so per-app context rules can read
         the foreground app; granted via the usage-access onboarding deep-link, not a runtime dialog. -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- F89 audit: the context-rule location gate + once-a-day circadian sun refresh read location
         from the foreground service while the UI is backgrounded (specialUse FGS, not a location FGS),
         which needs background-location access on API 29+. Declared so the capability exists; the
         "Allow all the time" upgrade is offered from the Setup Location step (a Settings deep-link). -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <!-- task528 panic: S.O.S. morse vibration pattern (prof769 → _PanicButton act0, code62). -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- task90 act28: geo-IP location fallback (HTTPS https://ipwho.is/) when no Android fix (F83/D-121). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- S14: ConnectivityManager (WifiInfoReader SSID NetworkCallback fallback) needs network state.
         A normal permission, auto-granted at install — its absence would SecurityException that path. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- F89 audit — android.permission.DUMP is intentionally NOT declared: it is signature|privileged,
         so it cannot be granted to a normal app. The no-Location SSID path's in-process `dumpsys wifi`
         (WifiSsidStrategies) is permission-denied without it and simply falls through to the next
         strategy (Shizuku `cmd wifi status` → Location callback). Declaring it would have no effect. -->


    <!-- Android 11+ package visibility: see launchable apps so the per-app context-rule picker is
         not empty (G2-F14). Mirrors Tasker's app-list query for prof762 _ContextAppChanged. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="${appLabel}"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.TideoAutoBrightness">

        <activity
            android:name=".app.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".app.runtime.AmbientMonitoringService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Continuous ambient-light monitoring to drive adaptive screen brightness" />
        </service>

        <service
            android:name=".app.runtime.BrightnessTileService"
            android:enabled="true"
            android:exported="true"
            android:icon="@drawable/ic_stat_brightness"
            android:label="Auto Brightness"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <receiver
            android:name=".app.runtime.BootCompletedReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Home-screen dashboard widget (Brightness / lux / profile / context + service toggle &
             reset). updatePeriodMillis=0: never polled — repainted event-driven from the running
             service's publish path. The custom TOGGLE/RESET actions are delivered via explicit
             PendingIntents from the widget's own buttons. -->
        <receiver
            android:name=".app.widget.DashboardWidgetProvider"
            android:enabled="true"
            android:exported="true"
            android:label="@string/widget_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.tideo.autobrightness.widget.action.TOGGLE" />
                <action android:name="com.tideo.autobrightness.widget.action.RESET" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/dashboard_widget_info" />
        </receiver>


        <!-- Opt-in global flash overlay (S12.7e, G2R-F50): draws the AAB debug/context flash
             messages system-wide via an accessibility overlay. Presentation only — no event
             consumption, no window-content retrieval. Degrades to a foreground toast when off. -->
        <service
            android:name=".app.runtime.AabToastAccessibilityService"
            android:enabled="true"
            android:exported="false"
            android:label="Auto Brightness global flashes"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/aab_accessibility_service" />
        </service>

        <!-- Shizuku: one-time WRITE_SECURE_SETTINGS grant channel (not a runtime binder dep). -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:exported="true"
            android:grantUriPermissions="true"
            android:multiprocess="false"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />
    </application>
</manifest>
